# Staging / preview — copy to .env.staging.local (gitignored)
# Vercel: set the same keys under Environment → Preview (not Production)

NEXT_PUBLIC_APP_ENV=staging
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_STAGING_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_staging_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_staging_service_role_key

# Preview deployment URL (Vercel sets NEXT_PUBLIC_VERCEL_URL automatically on preview)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional for push tests on staging
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
