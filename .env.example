# Production (live site) — set these in Vercel → Production only
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROD_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_prod_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_prod_service_role_key
NEXT_PUBLIC_SITE_URL=https://your-live-domain.com

# Optional: VAPID / push, email, Meta OAuth, site gate, etc.
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# NEXT_PUBLIC_META_APP_ID=
# META_APP_SECRET=
